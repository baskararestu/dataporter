# ─── Database Connections ────────────────────────────────
# For local dev (docker compose --profile local), use these:
SOURCE_DSN=postgres://emr_user:emr_pass@localhost:5433/database_emr?sslmode=disable
TARGET_DSN=postgres://simrs_user:simrs_pass@localhost:5434/database_simrs?sslmode=disable

# For external/VPS databases, point to your hosts:
# SOURCE_DSN=postgres://user:pass@emr-host:5432/database_emr?sslmode=require
# TARGET_DSN=postgres://user:pass@simrs-host:5432/database_simrs?sslmode=require

# ─── Migration Defaults ─────────────────────────────────
BATCH_SIZE=5000
BATCH_DELAY_MS=0

# ─── Server ─────────────────────────────────────────────
HTTP_PORT=8080
LOG_LEVEL=info

# ─── Local DB Settings (used by docker compose profile "local") ──
EMR_DB_NAME=database_emr
EMR_DB_USER=emr_user
EMR_DB_PASSWORD=emr_pass
EMR_DB_PORT=5433

SIMRS_DB_NAME=database_simrs
SIMRS_DB_USER=simrs_user
SIMRS_DB_PASSWORD=simrs_pass
SIMRS_DB_PORT=5434
