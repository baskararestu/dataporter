# Copy this file to .env, fill in your values. Never commit .env.

# ─── EMR Database (source, read-only) ───────────────────
EMR_DB_HOST=
EMR_DB_PORT=5432
EMR_DB_USER=
EMR_DB_PASSWORD=
EMR_DB_NAME=
EMR_DB_SSL_MODE=disable

# ─── SIMRS Database (target, read-write) ─────────────────
SIMRS_DB_HOST=
SIMRS_DB_PORT=5432
SIMRS_DB_USER=
SIMRS_DB_PASSWORD=
SIMRS_DB_NAME=
SIMRS_DB_SSL_MODE=disable

# ─── Migration Defaults ──────────────────────────────────
BATCH_SIZE=5000
BATCH_DELAY_MS=0

# ─── Server ──────────────────────────────────────────────
HTTP_PORT=8080
LOG_LEVEL=info
