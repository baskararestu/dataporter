# Copy this file to .env, fill in your values. Never commit .env.

# ─── PostgreSQL Connection ───────────────────────────────
# Single Postgres instance, two databases.
# The app auto-creates both databases on first startup.

# EMR Database (source, read-only)
EMR_DB_HOST=localhost
EMR_DB_PORT=5432
EMR_DB_USER=postgres
EMR_DB_PASSWORD=
EMR_DB_NAME=database_emr
EMR_DB_SSL_MODE=disable

# SIMRS Database (target, read-write) — same host, different DB name
SIMRS_DB_HOST=localhost
SIMRS_DB_PORT=5432
SIMRS_DB_USER=postgres
SIMRS_DB_PASSWORD=
SIMRS_DB_NAME=database_simrs
SIMRS_DB_SSL_MODE=disable

# ─── Migration Defaults ──────────────────────────────────
BATCH_SIZE=5000
BATCH_DELAY_MS=0

# ─── Server ──────────────────────────────────────────────
HTTP_PORT=8080
LOG_LEVEL=info
